---
import "../styles/global.css";

interface Props {
  title: string
  description?: string
}

const { title, description = 'Toolkit HTTP para desarrolladores full-stack' } = Astro.props
const PUBLIC_API_URL = import.meta.env.PUBLIC_API_URL
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · DevKit</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-gray-950 text-gray-100 font-sans">
    <nav class="border-b border-gray-800 px-6 py-4">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <a href={PUBLIC_API_URL} class="text-white font-bold text-xl tracking-tight">
          Dev<span class="text-blue-400">Kit</span>
        </a>
        <div class="flex items-center gap-6 text-sm text-gray-400">
          <a href={`${PUBLIC_API_URL}/playground`} class="hover:text-white transition-colors">Playground</a>
          <a href={`${PUBLIC_API_URL}/docs`} target="_blank" class="hover:text-white transition-colors">API Docs</a>
          <a href="https://github.com/wxzzxrdresurrection/DevKit-API" target="_blank" class="hover:text-white transition-colors">GitHub</a>
        </div>
      </div>
    </nav>

    <main class="max-w-5xl mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-gray-800 px-6 py-6 mt-12">
      <div class="max-w-5xl mx-auto text-center text-sm text-gray-600">
        DevKit · Hecho con Hono, Prisma y Astro
      </div>
    </footer>
  </body>
</html>