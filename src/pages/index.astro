---
import Layout from '../layouts/Layout.astro'

const tools = [
  {
    name: 'Imagen Placeholder',
    description: 'Genera imágenes de cualquier tamaño on-the-fly. Soporta jpeg, png y webp con color y texto personalizables.',
    endpoint: 'GET /img/400x300',
    badge: 'img',
    href: '/playground#img',
    color: 'blue',
  },
  {
    name: 'Generador de Texto',
    description: 'Lorem ipsum en palabras, oraciones o párrafos. Retorna en plain, JSON o HTML.',
    endpoint: 'GET /text?type=sentences&count=5',
    badge: 'text',
    href: '/playground#text',
    color: 'violet',
  },
  {
    name: 'Datos Ficticios',
    description: 'Genera usuarios, productos, posts y empresas con datos coherentes. Soporte para locale y seed reproducible.',
    endpoint: 'GET /fake/user?count=10',
    badge: 'fake',
    href: '/playground#fake',
    color: 'emerald',
  },
  {
    name: 'Mock API REST',
    description: 'Registra endpoints personalizados y consúmelos como una API real. Soporta delay, headers y cualquier método HTTP.',
    endpoint: 'POST /mock/create',
    badge: 'mock',
    href: '/playground#mock',
    color: 'amber',
  },
]

const colorMap: Record<string, string> = {
  blue:    'bg-blue-500/10 text-blue-400 border-blue-500/20',
  violet:  'bg-violet-500/10 text-violet-400 border-violet-500/20',
  emerald: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  amber:   'bg-amber-500/10 text-amber-400 border-amber-500/20',
}

const dotMap: Record<string, string> = {
  blue:    'bg-blue-400',
  violet:  'bg-violet-400',
  emerald: 'bg-emerald-400',
  amber:   'bg-amber-400',
}

const PUBLIC_API_URL = import.meta.env.PUBLIC_API_URL
console.log('PUBLIC_API_URL:', PUBLIC_API_URL)
---

<Layout title="Home">
  <!-- Hero -->
  <section class="text-center py-16">
    <div class="inline-flex items-center gap-2 bg-blue-500/10 text-blue-400 text-sm px-4 py-1.5 rounded-full border border-blue-500/20 mb-6">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>
      API pública · Sin auth · Sin setup
    </div>

    <h1 class="text-5xl font-bold text-white mb-4 tracking-tight">
      Herramientas para<br/>
      <span class="text-blue-400">devs que van rápido</span>
    </h1>

    <p class="text-gray-400 text-lg max-w-xl mx-auto mb-10">
      Imágenes, texto, datos ficticios y mock APIs disponibles desde una URL.
      Sin instalación, sin cuenta, sin fricción.
    </p>

    <div class="flex items-center justify-center gap-4">
      <a
        href={`${PUBLIC_API_URL}/playground`}
        class="bg-blue-500 hover:bg-blue-400 text-white font-medium px-6 py-2.5 rounded-lg transition-colors"
      >
        Abrir playground
      </a>
      <a
        href={`${PUBLIC_API_URL}/docs`}
        target="_blank"
        class="text-gray-400 hover:text-white border border-gray-700 hover:border-gray-500 px-6 py-2.5 rounded-lg transition-colors"
      >
        Ver API docs
      </a>
    </div>
  </section>

  <!-- Tools grid -->
  <section class="mt-8">
    <h2 class="text-sm font-medium text-gray-500 uppercase tracking-widest mb-6">Herramientas</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {tools.map(tool => (
        <a
          href={`${PUBLIC_API_URL}${tool.href.replace(/^\//, '')}`}
          class="group block bg-gray-900 border border-gray-800 hover:border-gray-600 rounded-xl p-6 transition-all"
        >
          <div class="flex items-start justify-between mb-3">
            <span class={`text-xs font-mono px-2.5 py-1 rounded-md border ${colorMap[tool.color]}`}>
              {tool.badge}
            </span>
            <span class="text-gray-600 group-hover:text-gray-400 transition-colors text-lg">↗</span>
          </div>

          <h3 class="text-white font-semibold text-lg mb-1">{tool.name}</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-4">{tool.description}</p>

          <div class="flex items-center gap-2">
            <span class={`w-1.5 h-1.5 rounded-full ${dotMap[tool.color]}`}></span>
            <code class="text-xs text-gray-500 font-mono">{tool.endpoint}</code>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Quick example -->
  <section class="mt-16 bg-gray-900 border border-gray-800 rounded-xl p-8">
    <h2 class="text-white font-semibold text-lg mb-6">Ejemplo rápido</h2>
    <div class="space-y-3 font-mono text-sm">
      <div class="flex gap-3">
        <span class="text-gray-600 select-none">1</span>
        <span class="text-gray-400"># Obtener 5 usuarios ficticios en español</span>
      </div>
      <div class="flex gap-3">
        <span class="text-gray-600 select-none">2</span>
        <span><span class="text-blue-400">curl</span> <span class="text-emerald-400">{PUBLIC_API_URL}/fake/user?count=5&locale=es</span></span>
      </div>
      <div class="flex gap-3">
        <span class="text-gray-600 select-none">3</span>
        <span class="text-gray-400"></span>
      </div>
      <div class="flex gap-3">
        <span class="text-gray-600 select-none">4</span>
        <span class="text-gray-400"># Imagen de 800x400 con fondo personalizado</span>
      </div>
      <div class="flex gap-3">
        <span class="text-gray-600 select-none">5</span>
        <span><span class="text-blue-400">curl</span> <span class="text-emerald-400">{PUBLIC_API_URL}/img/800x400?bg=1E3A5F&text=Banner</span></span>
      </div>
    </div>
  </section>
</Layout>